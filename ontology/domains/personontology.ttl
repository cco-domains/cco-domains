###  https://purl.org/cco/ent00000001
cco:ent00000001 rdf:type owl:Class ;
                rdfs:subClassOf cco:ont00000003 ;
                dcterms:created "2026-04-23"^^xsd:date ;
                rdfs:isDefinedBy <https://purl.org/cco/person> ;
                rdfs:label "Full Name"@en ;
                skos:definition "A Designative Name comprising all or most of a person's various names, e.g. Given Name, Alternate Name, Family Name, etc. but may include initials for some names, as presented by the individual, who may give different versions at different times."@en .


###  https://purl.org/cco/ent00000002
cco:ent00000002 rdf:type owl:Class ;
                rdfs:subClassOf cco:ont00000003 ;
                dcterms:created "2026-04-23"^^xsd:date ;
                rdfs:isDefinedBy <https://purl.org/cco/person> ;
                rdfs:label "Given Name"@en ;
                skos:altLabel "First Name"@en ;
                skos:definition "A designative Name assigned to a person, usually at birth."@en .


###  https://purl.org/cco/ent00000004
cco:ent00000004 rdf:type owl:Class ;
                rdfs:subClassOf cco:ont00000003 ;
                dcterms:created "2026-04-28"^^xsd:date ;
                rdfs:isDefinedBy <https://purl.org/cco/person> ;
                rdfs:label "Family Name"@en ;
                skos:altLabel "Last Name"@en ,
                              "Surname"@en ;
                skos:definition "A designative name often referred to as a \"last name\" in Western contexts or a \"surname\" in formal contexts."@en .


###  https://purl.org/cco/ent00000008
cco:ent00000008 rdf:type owl:Class ;
                rdfs:subClassOf cco:ent00000062 ;
                dcterms:created "2026-04-20"^^xsd:date ;
                dcterms:source <https://www.ssa.gov/employer/ssnvshandbk/glossary.htm> ;
                rdfs:isDefinedBy <https://purl.org/cco/person> ;
                rdfs:label "Social Security Number"@en ;
                skos:altLabel "SSN"@en ;
                skos:definition "A Person Identifier issued by the U.S. Social Security Administration."@en ;
                skos:example "123-45-6789 (dashes common but not required)"@en .


###  https://purl.org/cco/ent00000046
cco:ent00000046 rdf:type owl:Class ;
                rdfs:subClassOf cco:ont00001340 ;
                dcterms:created "2026-04-14"^^xsd:date ;
                rdfs:isDefinedBy <https://purl.org/cco/person> ;
                rdfs:label "Birthdate"@en ;
                skos:altLabel "DOB"@en ,
                              "date of birth"@en ;
                skos:definition "A Calendar Date Identifier designating when a Person was born."@en .


###  https://purl.org/cco/ent00000062
cco:ent00000062 rdf:type owl:Class ;
                rdfs:subClassOf cco:ont00000649 ;
                dcterms:created "2026-04-20"^^xsd:date ;
                rdfs:isDefinedBy <https://purl.org/cco/person> ;
                rdfs:label "Person Identifier"@en ;
                skos:altLabel "PersonIdentifier"@en ;
                skos:definition "A non-Name Identifier for a person."@en .


