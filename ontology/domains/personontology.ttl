###  https://purl.org/cco/ent00000061
cco:ent00000061 rdf:type owl:ObjectProperty ;
                rdfs:domain cco:ont00001262 ;
                rdfs:range cco:ent00000046 ;
                dcterms:created "2026-04-18"^^xsd:date ;
                rdfs:isDefinedBy <https://purl.org/cco/person> ;
                rdfs:label "has birthdate"@en ;
                skos:altLabel "hasBirthdate"@en ;
                skos:definition "Each instance of Person has an instance of Birthdate."@en .


