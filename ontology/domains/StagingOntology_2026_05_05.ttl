###  https://purl.org/cco/ent00000023
cco:ent00000023 rdf:type owl:Class ;
                rdfs:subClassOf cco:ont00000958 ;
                dcterms:created "2026-05-05"^^xsd:date ;
                rdfs:isDefinedBy <https://purl.org/cco/staging> ;
                rdfs:label "Telephone Number"@en ;
                skos:altLabel "Phone Number"@en ;
                skos:definition "An Information Content Entity (ICE) that consists of a unique sequence of digits assigned to a particular telecommunication endpoint, enabling that person to be contacted through a telephone network."@en ;
                skos:example "+1 (212) 555-0321"@en .


###  https://purl.org/cco/ent00000024
cco:ent00000024 rdf:type owl:Class ;
                rdfs:subClassOf cco:ont00000958 ;
                dcterms:created "2026-05-05"^^xsd:date ;
                rdfs:isDefinedBy <https://purl.org/cco/staging> ;
                rdfs:label "Email Address"@en ;
                skos:altLabel "Electronic Mail Address"@en ,
                              "Email ID"@en ;
                skos:definition "An Information Content Entity (ICE) that consists of a unique address assigned to a person, enabling the sending and receiving of electronic messages through a mail server over the network."@en ;
                skos:example "james.schoening@ieee.org, aroobasultantiwana@gmail.com"@en .


