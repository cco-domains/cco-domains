###  https://purl.org/cco/ent00000044
cco:ent00000044 rdf:type owl:Class ;
                rdfs:subClassOf cco:ent00000037 ;
                dcterms:created "2026-07-11"^^xsd:date ;
                rdfs:isDefinedBy <https://purl.org/cco/person> ;
                rdfs:label "Hazel Eye Color"@en ;
                skos:closeMatch cco:ont00000797 ;
