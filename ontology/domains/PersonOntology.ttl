                rdfs:isDefinedBy <https://purl.org/cco/person> ;
                rdfs:label "Pink/Red Eye Color"@en ;
                skos:closeMatch cco:ont00001277 ;
                skos:definition "An Eye Color that appears pink or light red due to lack of pigment."@en .


###  https://purl.org/cco/ent00000065
cco:ent00000065 rdf:type owl:Class ;
                rdfs:subClassOf cco:ent00000062 ;
                dcterms:created "2026-07-11"^^xsd:date ;
                rdfs:isDefinedBy <https://purl.org/cco/person> ;
                rdfs:label "Drivers License Number"@en ;
                skos:definition "A Person Identifier issued to a person by a driver-licensing authority."@en .


###  https://purl.org/cco/ent00000066
cco:ent00000066 rdf:type owl:Class ;
                rdfs:subClassOf cco:ent00000062 ;
                dcterms:created "2026-07-11"^^xsd:date ;
                rdfs:isDefinedBy <https://purl.org/cco/person> ;
                rdfs:label "Passport Number"@en ;
                skos:definition "A Person Identifier issued to a person by a passport-issuing authority."@en .


###  https://purl.org/cco/ent00000067
cco:ent00000067 rdf:type owl:Class ;
                rdfs:subClassOf cco:ont00000686 ;
                dcterms:created "2026-07-11"^^xsd:date ;
                rdfs:isDefinedBy <https://purl.org/cco/person> ;
                rdfs:label "Place of Birth"@en ;
                skos:definition "A Designative Information Content Entity that cites the civil jurisdiction in which a person's birth was registered as taking place, as recorded on an identity document. The registering jurisdiction may differ from the geographic location of the birth."@en .


###  https://purl.org/cco/ent00000068
cco:ent00000068 rdf:type owl:Class ;
                rdfs:subClassOf cco:ont00000686 ;
                dcterms:created "2026-07-11"^^xsd:date ;
                rdfs:isDefinedBy <https://purl.org/cco/person> ;
                rdfs:label "Issuing Jurisdiction"@en ;
                skos:definition "A Designative Information Content Entity that cites the governmental jurisdiction that issued an identity document, as recorded on that document. Designates a governing authority (e.g., national, state, provincial, agency, county, municipal, utility, etc.), not a postal address component."@en .


