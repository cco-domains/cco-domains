###  https://purl.org/cco/ent00000046
cco:ent00000046 rdf:type owl:Class ;
                rdfs:subClassOf cco:ont00001340 ;
                dcterms:created "2026-04-14"^^xsd:date ;
                rdfs:isDefinedBy <https://purl.org/cco/person> ;
                rdfs:label "Birthdate"@en ;
                skos:altLabel "DOB"@en ,
                              "date of birth"@en ;
                skos:definition "A Calendar Date Identifier designating when a Person was born."@en .


###  https://purl.org/cco/ent00000057
cco:ent00000057 rdf:type owl:Class ;
                rdfs:subClassOf cco:ont00000003 ;
                dcterms:created "2026-05-01"^^xsd:date ;
                rdfs:isDefinedBy <https://purl.org/cco/person> ;
                rdfs:label "Title"@en ;
                skos:altLabel "Honorific"@en ,
                              "Name Prefix"@en ;
                skos:definition "A designative name added before the person's given name to add more information (professional, marital status or religious)."@en ;
                skos:example "\"Mr.\". \"Dr.\". \"Prof.\""@en .


###  https://purl.org/cco/ent00000058
cco:ent00000058 rdf:type owl:Class ;
                rdfs:subClassOf cco:ont00000003 ;
                dcterms:created "2026-05-01"^^xsd:date ;
                rdfs:isDefinedBy <https://purl.org/cco/person> ;
                rdfs:label "Surname2"@en ;
                skos:altLabel "Maternal Name"@en ,
                              "Second Family Name"@en ,
                              "Second Surname"@en ;
