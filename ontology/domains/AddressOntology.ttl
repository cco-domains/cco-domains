###  https://purl.org/cco/ent00000009
cco:ent00000009 rdf:type owl:Class ;
                rdfs:subClassOf cco:ent00000310 ;
                dcterms:created "2026-06-15" ;
                rdfs:isDefinedBy <https://purl.org/cco/address> ;
                rdfs:label "Postal Address"@en ;
                skos:altLabel "Mailing Address"@en ;
                skos:definition "An address that designates a place where physical mail or packages can be sent via the postal service."@en ;
                skos:exactMatch <https://schema.org/PostalAddress> .


###  https://purl.org/cco/ent00000010
cco:ent00000010 rdf:type owl:Class ;
