                rdfs:label "US Postal Address"@en ;
                skos:altLabel "United States Postal Address"@en ;
                skos:definition "A postal address that complies with USPS addressing requirements and includes the delivery location line, city, dual-letter state identifier, and ZIP code."@en ;
