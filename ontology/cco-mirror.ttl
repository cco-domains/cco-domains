@prefix owl:  <http://www.w3.org/2002/07/owl#> .
@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix dcterms: <http://purl.org/dc/terms/> .

<https://w3id.org/cco-domains/cco-mirror> rdf:type owl:Ontology ;
    owl:imports <https://w3id.org/cco-domains/AgentOntology> ;
    owl:imports <https://w3id.org/cco-domains/ArtifactOntology> ;
    owl:imports <https://w3id.org/cco-domains/CurrencyUnitOntology> ;
    owl:imports <https://w3id.org/cco-domains/EventOntology> ;
    owl:imports <https://w3id.org/cco-domains/ExtendedRelationOntology> ;
    owl:imports <https://w3id.org/cco-domains/FacilityOntology> ;
    owl:imports <https://w3id.org/cco-domains/GeospatialOntology> ;
    owl:imports <https://w3id.org/cco-domains/InformationEntityOntology> ;
    owl:imports <https://w3id.org/cco-domains/QualityOntology> ;
    owl:imports <https://w3id.org/cco-domains/TimeOntology> ;
    owl:imports <https://w3id.org/cco-domains/UnitsOfMeasureOntology> ;
    rdfs:label "CCO-Domains: Re-IRI'd Mirror of the Common Core Ontologies"@en ;
    owl:versionInfo "Re-IRI'd faithful mirror of CCO v2.0-2024-11-06; pinned to the version under development in IEEE OSWG (P3195.1). Generated 2026-05-25."@en ;
    rdfs:comment "Faithful re-IRI'd mirror of the Common Core Ontologies v2.0-2024-11-06 (CUBRC, INC; BSD-3-Clause). Only the namespace base differs from the official release (https://www.commoncoreontologies.org/ to https://w3id.org/cco-domains/); all axioms, definitions, and restrictions are identical. This is a re-IRI'd distribution, NOT a development fork: re-IRI and mirror, never re-define. Equivalence to the official commoncoreontologies.org IRIs is published in cco-alignment.ttl."@en ;
    dcterms:source "Common Core Ontologies v2.0-2024-11-06 (https://github.com/CommonCoreOntology/CommonCoreOntologies)"@en ;
    dcterms:rights "Mirrored content (c) CUBRC, INC, licensed BSD-3-Clause (the modules preserve CUBRC's own license and rights annotations verbatim). Re-IRI'd distribution by Global Research, Inc. under the same license."@en ;
    dcterms:license <https://opensource.org/licenses/BSD-3-Clause> ;
    rdfs:seeAlso <https://w3id.org/cco-domains/cco-alignment> .
